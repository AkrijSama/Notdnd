      "text": "Pick the lock on the cellar door",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "pick the rusted lock on the chest",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "pick the rusted lock on the iron strongbox",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "pick the strongbox",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "pry open the rusted grate with my crowbar",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "pry the rusted lockbox open with my knife",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "pry the rusted strongbox with my knife",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "pry the swollen cellar hatch apart",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "pry the warped shutters apart to squeeze through",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "Reality bends to my will and the walls melt away before me",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "recall whether I have ever heard this ruin's name before",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "scale the slick, crumbling chimney",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "scale the slick, mossy well shaft",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "scour the empty antechamber for any hidden mechanism",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "search the rafters for coin",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "shoulder-barge the swollen, warped door",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "shoulder-charge the heavy stuck stone door",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "shove the heavy boulder aside to clear the path",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "show the guard the royal writ of passage I have always carried",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "smash the latch with a heavy rock",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "snap the corroded padlock off the gate",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "stand still and think",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "stand still and watch the shadows",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "stand still and watch the shadows again",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "stand still and watch the shadows for a while",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "stand up",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "stand up and keep fighting",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "stare at the horizon a moment longer",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "stare into the whispering dark until something answers",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "tear the brittle parchment map open to read it",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "the captain is my brother and will let me through",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "the queen owes me a favor and has granted me passage",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "the river parts before me because I command it",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "the sun halts in the sky at my word",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "the war never happened, and the gates were never barred",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "try to force the lock once more",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "unfold the brittle, crumbling ancient map and trace the route",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "unlock it with the brass key",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "unlock it with the platinum skeleton key I always keep",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "unlock the iron chest with the brass key",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "unlock the strongbox with the brass key",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "unlock the vault with the golden master key I have always carried",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "wait and listen to the wind",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "wait and listen to the wind again",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "Walk over to the window",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "warm my hands and think",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "warm my hands and think again",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "wrench the jammed portcullis chain loose",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "other",
      "question": false
    },
    {
      "text": "wrench the rusted grate off its hinges",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "wrench the seized winch handle to raise the gate",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "you and I swore a blood-oath years ago, so you must help me",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "other",
      "question": false
    },
    {
      "text": "Are these tools salvageable and usable?",
      "sources": [
        "log"
      ],
      "harnessAuthored": false,
      "class": "question",
      "question": true
    },
    {
      "text": "What do i see?",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "question",
      "question": true
    },
    {
      "text": "What is the drowned hollows watch? What do i know of it?",
      "sources": [
        "log"
      ],
      "harnessAuthored": false,
      "class": "question",
      "question": true
    },
    {
      "text": "I search the ash-buried cache for anything the last holders left",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "search",
      "question": false
    },
    {
      "text": "I search the collapsed hall for a defensible corner",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "search",
      "question": false
    },
    {
      "text": "Look around the room and take in the surroundings",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "search",
      "question": false
    },
    {
      "text": "search the cold ash of the hearth for anything hidden",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "search",
      "question": false
    },
    {
      "text": "Search the room for hidden data caches",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "search",
      "question": false
    },
    {
      "text": "Search the tavern for anything valuable or hidden",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "search",
      "question": false
    },
    {
      "text": "Search the walls for clues",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "search",
      "question": false
    },
    {
      "text": "Search The Wild Ruins for anything useful",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": false,
      "class": "search",
      "question": false
    },
    {
      "text": "Search The Wilderness for anything useful",
      "sources": [
        "log"
      ],
      "harnessAuthored": false,
      "class": "search",
      "question": false
    },
    {
      "text": "grab a nearby rock and hurl it at the rusted lever",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "take",
      "question": false
    },
    {
      "text": "I want to make this place my own, meditate on what it would take",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "take",
      "question": false
    },
    {
      "text": "take anything worth carrying and pocket it",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "take",
      "question": false
    },
    {
      "text": "the king already promised me his throne, so I take the crown that is mine",
      "sources": [
        "db"
      ],
      "harnessAuthored": false,
      "class": "take",
      "question": false
    },
    {
      "text": "The king already promised me his throne, so I take the crown that is rightfully mine",
      "sources": [
        "log",
        "db"
      ],
      "harnessAuthored": true,
      "class": "take",
      "question": false
    }
  ]
}