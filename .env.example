# NotDND — environment configuration template
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# Every variable the server reads is listed below. Values shown after `=` on
# commented (`#`) lines are the built-in DEFAULTS — uncomment and change only
# what you need. The server runs out of the box with NO env vars set by using
# mock/placeholder providers, but real AI text + image generation require keys.

# =============================================================================
# Brand rename: NotDND -> Inkborne
# -----------------------------------------------------------------------------
# Env vars are migrating from the NOTDND_* prefix to INKBORNE_*. The server
# reads INKBORNE_* first and falls back to the legacy NOTDND_* when unset, so
# existing deployments keep working with their old vars. Vars shown below with
# the INKBORNE_ prefix already have this fallback; remaining NOTDND_* vars
# (further down) are pending migration and still use NOTDND_* only.
# =============================================================================

# =============================================================================
# Required — AI routing (text / GM narration)
# =============================================================================
# OpenRouter is the default text provider. Without a key the server falls back
# to mock GM responses (set INKBORNE_MOCK_OPENROUTER=true to force this offline).
#
# GM narration provider (OpenAI-compatible endpoint)
# Default: OpenRouter. Swap to any OpenAI-compatible provider:
# Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
#         chat/completions
# Groq:   https://api.groq.com/openai/v1/chat/completions
INKBORNE_LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions
INKBORNE_LLM_API_KEY=your_api_key_here
# Legacy: NOTDND_* still works as fallback. OPENROUTER_API_KEY is also honored.
#NOTDND_LLM_BASE_URL=
#NOTDND_LLM_API_KEY=
#OPENROUTER_API_KEY=your_openrouter_key_here
# Model used for GM narration / world prose. (code default: x-ai/grok-3)
INKBORNE_GM_MODEL=openai/gpt-oss-120b:free
# Cheaper model for utility/structured calls. (code default: venice/uncensored:free)
INKBORNE_UTILITY_MODEL=openai/gpt-oss-20b:free
# Fallback model if the primary errors. (code default: meta-llama/llama-3.3-70b-instruct:free)
#INKBORNE_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Legacy: NOTDND_GM_MODEL / NOTDND_UTILITY_MODEL / NOTDND_FALLBACK_MODEL still work as fallback.
# Cloud->local GM fallback (ollama inkborne-gm:8b).
# GPU-unsafe if true on 8GB VRAM — enable per-session only, never persist
INKBORNE_GM_LOCAL_FALLBACK=false

# --- TESTING-ONLY two-lane free cloud chain (Gemini Flash -> Groq -> local) ------
# For the owner's VALIDATION PLAYTHROUGH: fast, good-quality FREE cloud prose that
# won't cap to the slow local 8b mid-session. Independent free quotas (each ~1000-
# 1500 req/day, no card) so capping one falls to the next, then local as last resort.
# WARNING: NOT a product default. Gemini's free tier TRAINS ON PROMPTS and has no
# SLA — fine for solo testing, WRONG for shipped product. Leave this UNSET/off for
# anything real; when unset the app behaves exactly as before (OpenRouter path).
#   Value: "gemini-groq" (ordered), "on"/"true" (= gemini-groq), or "off"/unset.
#   Reverse to "groq-gemini" if you want sub-second Groq PRIMARY over Gemini prose.
#NOTDND_CLOUD_PROVIDER_CHAIN=gemini-groq
# Gemini 2.5 Flash — free key at https://ai.google.dev (AI Studio, "Get API key", no card):
#GEMINI_API_KEY=your_gemini_api_key_here
#GEMINI_MODEL=gemini-2.5-flash
# Groq — free key at https://console.groq.com (sub-second 70B; confirm current model):
#GROQ_API_KEY=your_groq_api_key_here
#GROQ_MODEL=llama-3.3-70b-versatile
# Endpoints are OpenAI-compatible and env-overridable if a provider URL changes:
#GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
#GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# --- PERSONAL-TESTING "codex" lane (OWNER ONLY — never a product lane) -----------
# Routes GM calls through the owner's ChatGPT subscription (Codex backend,
# gpt-5.5) via the local sidecar proxy for prose-ceiling A/B and interpreter-
# reliability comparison. SUBSCRIPTION-BOUND: rolling usage window, no SLA,
# unofficial endpoint that can change without notice — it must NEVER serve
# external users. OFF unless "codex" is NAMED in the chain, and ALWAYS skipped
# for battery/harness callers (NOTDND_BATTERY / x-notdnd-battery). Requires the
# Codex CLI logged in (~/.codex/auth.json) and the sidecar running:
#     node server/ai/codex-proxy.mjs
#NOTDND_CLOUD_PROVIDER_CHAIN=codex-groq
# Sidecar location + serving model (defaults shown):
#CODEX_PROXY_URL=http://127.0.0.1:8788/v1/chat/completions
#NOTDND_CODEX_PROXY_PORT=8788
#CODEX_MODEL=gpt-5.5
# Codex CLI login file, read by the sidecar — NEVER commit/copy its contents.
#CODEX_AUTH_PATH=~/.codex/auth.json
# gpt-5.5 is a reasoning model; per-attempt window for the codex lane (ms):
#NOTDND_GM_CODEX_TIMEOUT_MS=60000
# Reasoning effort forwarded by the sidecar ("off" omits the field):
#CODEX_REASONING_EFFORT=low
# A/B raw material: capture every GM call's exact messages to
# data/logs/gm-capture.jsonl for scripts/prose-ab.mjs replay. Owner testing only.
#NOTDND_GM_CAPTURE=1
# Battery marker: any truthy value marks this process's traffic as automated
# harness traffic, which skips the codex lane regardless of chain config.
# (Set automatically by scripts/start-test-server.mjs and the selfplay harness.)
#NOTDND_BATTERY=1

# =============================================================================
# Required — Image generation
# =============================================================================
# Provider for location backgrounds + NPC/player portraits.
# Values: pollinations | fal | mock  (empty/unset => mock placeholder PNGs)
INKBORNE_IMAGE_PROVIDER=pollinations
# Legacy: NOTDND_IMAGE_PROVIDER still works as fallback.
#NOTDND_IMAGE_PROVIDER=pollinations
# Pollinations tuning (defaults shown). Legacy NOTDND_* still works as fallback.
#INKBORNE_POLLINATIONS_ENDPOINT=https://image.pollinations.ai/prompt
#INKBORNE_POLLINATIONS_MODEL=flux
# Public origin prepended to served asset URIs so REMOTE image providers can
# fetch reference portraits. Leave blank for local/offline runs.
#NOTDND_PUBLIC_ASSET_BASE=
# On-disk directory where generated image bytes are written. (default: data/assets)
#NOTDND_ASSETS_ROOT=data/assets

# =============================================================================
# Optional — Run offline without real AI (for CI / testing)
# =============================================================================
# Force mock GM responses even if an API key is set.
INKBORNE_MOCK_OPENROUTER=false
# Force a tiny placeholder PNG instead of calling any image provider.
INKBORNE_MOCK_IMAGE=false
# Legacy: NOTDND_MOCK_OPENROUTER / NOTDND_MOCK_IMAGE still work as fallback.

# =============================================================================
# Optional — Cloudflare Workers AI (free-tier FLUX-1-schnell; image failover #2)
# =============================================================================
# When BOTH are set, Cloudflare is added to the image failover chain after
# Pollinations (auto-skipped when unset). flux-1-schnell has a fixed output size.
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token

# =============================================================================
# Optional — fal.ai (when Pollinations is insufficient; img2img / face-id)
# =============================================================================
FAL_API_KEY=your_fal_key_here
#NOTDND_FAL_ENDPOINT=https://fal.run/fal-ai/flux/dev
#NOTDND_FAL_FACE_ENDPOINT=https://fal.run/fal-ai/ip-adapter-face-id
#NOTDND_FAL_IMAGE_MODEL=fal-ai/flux/dev

# =============================================================================
# Optional — Local model (Forbidden Mode / expression variants)
# =============================================================================
# Reserved for a local LLM runtime (e.g. Ollama). The built-in `local` provider
# is currently a mock; these vars override its model labels.
NOTDND_LOCAL_MODEL_URL=http://localhost:11434
#NOTDND_LOCAL_GM_MODEL=local-gm-v1
#NOTDND_LOCAL_IMAGE_MODEL=local-image-v1
#NOTDND_LOCAL_VOICE_MODEL=local-voice-v1

# =============================================================================
# Optional — Provider selection switches (default to placeholder/local/mock)
# =============================================================================
# GM narration provider for the solo Attempt loop. (default: placeholder)
#NOTDND_GM_PROVIDER=placeholder
# Generic AI job provider. (default: local)
#NOTDND_AI_PROVIDER=local
# Text provider used by world-gen + NPC identity unless overridden below.
#NOTDND_TEXT_PROVIDER=placeholder
# Per-feature text provider overrides (fall back to NOTDND_TEXT_PROVIDER).
#NOTDND_WORLD_PROVIDER=placeholder
#NOTDND_NPC_IDENTITY_PROVIDER=placeholder

# =============================================================================
# Optional — Alternate AI providers (only if selected above)
# =============================================================================
# ChatGPT (OpenAI Responses API)
#OPENAI_API_KEY=
#NOTDND_CHATGPT_ENDPOINT=https://api.openai.com/v1/responses
#NOTDND_CHATGPT_GM_MODEL=gpt-5-mini
#NOTDND_CHATGPT_IMAGE_MODEL=gpt-image-1
#NOTDND_CHATGPT_VOICE_MODEL=gpt-4o-mini-tts
# Grok (xAI)
#XAI_API_KEY=
#NOTDND_GROK_ENDPOINT=https://api.x.ai/v1/chat/completions
#NOTDND_GROK_GM_MODEL=grok-4-fast-reasoning
#NOTDND_GROK_IMAGE_MODEL=grok-2-image
#NOTDND_GROK_VOICE_MODEL=grok-voice-preview
# Gemini (Google)
#GEMINI_API_KEY=
#NOTDND_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent
#NOTDND_GEMINI_GM_MODEL=gemini-2.5-flash
#NOTDND_GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
#NOTDND_GEMINI_VOICE_MODEL=gemini-2.5-flash-preview-tts

# =============================================================================
# Optional — Server runtime
# =============================================================================
#PORT=4173
# Bind host. NOTDND_HOST wins over HOST. (default: 0.0.0.0)
#NOTDND_HOST=0.0.0.0
#HOST=0.0.0.0
# Seed a demo account (demo@notdnd.local / demo1234) on first start when no
# users exist. Set to true only for local development. Never enable in production.
NOTDND_BOOTSTRAP_DEMO=false

# =============================================================================
# Optional — Storage paths
# =============================================================================
# SQLite datastore path.
# Production: set to /data/notdnd.db (mounted persistent volume)
# Local dev: leave unset (defaults to ./server/db/notdnd.sqlite)
# Legacy: NOTDND_DB_PATH still works as fallback.
#INKBORNE_DB_PATH=/data/notdnd.db
#NOTDND_DB_PATH=/data/notdnd.db
# Root for campaign/NPC memory markdown. (default: data/campaigns)
#NOTDND_MEMORY_ROOT=data/campaigns
# Waitlist JSON file. (default: server/db/waitlist.json)
#NOTDND_WAITLIST_PATH=server/db/waitlist.json

# =============================================================================
# Optional — Payments (LemonSqueezy webhook → tier). GROUNDWORK, NOT go-live.
# =============================================================================
# The $9.99 "adventurer" sub via LemonSqueezy (Merchant-of-Record, ~5% + $0.50).
# The webhook flips a buyer's tier from a VERIFIED receipt, replacing the admin
# set-tier stopgap. The route (POST /api/webhooks/lemonsqueezy) is DISABLED until
# the secret below is set — going live is a deliberate launch decision (real
# store + product variants + this secret in prod). Never commit real values.
#   Webhook signing secret from the LemonSqueezy store settings:
#LEMONSQUEEZY_WEBHOOK_SECRET=
#   Map store variant ids -> tiers (the $9.99 sub; premium only if the adult-tier
#   processor question in docs/PRODUCT-ARCHITECTURE.md §4.1 is resolved go):
#LEMONSQUEEZY_VARIANT_ADVENTURER=
#LEMONSQUEEZY_VARIANT_PREMIUM=
# Admin stopgap (still available; grants a tier without a receipt). 404 when unset.
#INKBORNE_ADMIN_KEY=

# =============================================================================
# Optional — Auth / bootstrap account (created on first run)
# =============================================================================
#NOTDND_BOOTSTRAP_EMAIL=demo@notdnd.local
#NOTDND_BOOTSTRAP_PASSWORD=demo1234
#NOTDND_BOOTSTRAP_DISPLAY_NAME=Demo GM
# Session lifetime in seconds. (default: 604800 = 7 days)
#NOTDND_SESSION_TTL_SECONDS=604800
# Password hashing rounds. (default: 210000)
#NOTDND_PBKDF2_ITERATIONS=210000
# Realtime edit-lock TTL in ms. (default: 30000)
#NOTDND_LOCK_TTL_MS=30000

# =============================================================================
# Optional — Tuning
# =============================================================================
# Bounded await (ms) for GM narration on an action before falling back. (default: 12000)
#NOTDND_GM_ACTION_TIMEOUT_MS=12000
# Token budget for assembled GM context. (default: 1500)
#NOTDND_CONTEXT_BUDGET=1500
# Max bytes for homebrew URL imports. (default: 1200000)
#NOTDND_IMPORT_MAX_BYTES=1200000
# Enable realtime streaming. (default: false)
#NOTDND_STREAM=false

# =============================================================================
# Optional — Test / CI harness (read by scripts/, not the running server)
# =============================================================================
#E2E_PORT=4178
#SMOKE_PORT=4176
#SMOKE_AI_PORT=4177
#PLAYWRIGHT_ENTRY=
#CHROME_BIN=
#GOOGLE_CHROME_BIN=
